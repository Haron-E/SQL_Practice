01 - Sample Test Query:
SELECT 
    42 AS magic_number,
    'Hello from DBeaver!' AS greeting,
    CURRENT_DATE AS today,
    CURRENT_TIMESTAMP AS right_now;

02 - Creation nand Insertion into a Table:
create table Aloha(
	Employee_Id serial primary key,
	Name varchar(50),
	Age int,
	Gender varchar(10),
	Email varchar(50),
	position varchar(15),
	Branch_Location varchar(20)
);

insert into Aloha(name, age, gender, email, position, branch_location)
values
